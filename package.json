{
  "name": "vite-plugin-tla-polyfill",
  "version": "1.0.3",
  "description": "Transform code to support top-level await in normal browsers for Vite.",
  "main": "./exports/require.cjs",
  "module": "./exports/import.mjs",
  "exports": {
    "import": {
      "types": "./dist/index.d.ts",
      "default": "./exports/import.mjs"
    },
    "require": {
      "types": "./exports/require.d.cts",
      "default": "./exports/require.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DemonStore/vite-plugin-tla-polyfill.git"
  },
  "author": "Dmitry Los",
  "license": "MIT",
  "keywords": [
    "vite",
    "plugin",
    "top-level await",
    "await"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest --verbose --coverage",
    "format": "prettier --write '**/*.{mjs,cjs,js,ts}'"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/estree": "^1.0.6",
    "cz-conventional-changelog": "^3.3.0",
    "esbuild": "^0.25.6",
    "jest": "29.7.0",
    "jest-extended": "^6.0.0",
    "prettier": "^3.6.2",
    "ts-jest": "29.2.6",
    "typescript": "^5.8.3",
    "vite": "^7.0.5"
  },
  "dependencies": {
    "acorn": "^8.14.0",
    "acorn-walk": "^8.3.0",
    "magic-string": "^0.30.17",
    "@ampproject/remapping": "^2.3.0",
    "@rollup/plugin-virtual": "^3.0.2"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "files": [
    "/dist",
    "!/dist/**/*.spec.js",
    "!/dist/**/*.spec.d.ts",
    "/exports"
  ],
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
